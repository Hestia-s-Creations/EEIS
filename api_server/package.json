{
  "name": "watershed-disturbance-mapping-api",
  "version": "1.0.0",
  "description": "API server for Watershed Disturbance Mapping System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate-docs": "swagger-jsdoc -d config/swagger.js -o docs/openapi.json routes/*.js",
    "db:init": "node scripts/init-db.js init",
    "db:reset": "node scripts/init-db.js reset",
    "db:seed": "node scripts/init-db.js seed",
    "db:admin": "node scripts/init-db.js admin",
    "db:setup": "node scripts/init-db.js all",
    "sync-db": "node scripts/init-db.js init"
  },
  "keywords": [
    "watershed",
    "satellite",
    "mapping",
    "gps",
    "nodejs",
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "geojson": "^0.5.0",
    "shapefile": "^0.6.6",
    "sharp": "^0.33.1",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^3.0.6",
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-node": "^4.1.0",
    "@babel/preset-env": "^7.23.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
